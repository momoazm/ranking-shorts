# Copy this file to `helper.env` (same folder) and fill in the token. `helper.env` is gitignored.

# Fine-grained GitHub PAT with **Actions: Read** on momoazm/clipping-auto + momoazm/ranking-shorts.
# The SAME token you set in Vercel as GH_DISPATCH_TOKEN works here (the helper only needs read).
GH_DISPATCH_TOKEN=

# How often to check GitHub for a queued job (seconds). 20 is plenty.
POLL_SECONDS=20

# Runner install folders — override only if yours differ from these defaults.
RUNNER_DIR_CLIPPING=C:\actions-runner
RUNNER_DIR_RANKING=C:\actions-runner-ranking
