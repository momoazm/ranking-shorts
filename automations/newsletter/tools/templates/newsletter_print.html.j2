<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>
  @import url('https://fonts.googleapis.com/css2?family={{ theme.fonts.display.google_font | replace(' ', '+') }}:wght@700&family={{ theme.fonts.body.google_font | replace(' ', '+') }}:wght@400;600&display=swap');

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    background: {{ theme.colors.navy }};
    color: {{ theme.colors.text_on_dark }};
    font-family: '{{ theme.fonts.body.google_font }}', {{ theme.fonts.body.fallback_stack }};
    font-size: 13px;
    line-height: 1.5;
  }
  .page { max-width: 640px; margin: 0 auto; }

  .header { text-align: center; padding: 18px 24px 10px; }
  .header img { max-height: 42px; }
  .kicker {
    color: {{ theme.colors.gold }};
    font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
    margin-top: 8px;
  }
  .divider {
    height: 2px; width: 56px; background: {{ theme.colors.gold }};
    margin: 10px auto 0; border-radius: 1px;
  }

  .section {
    padding: 10px 24px;
    display: flow-root; /* contains the floated .pic so it can't bleed into neighboring sections */
    break-inside: avoid;
    page-break-inside: avoid;
  }
  .section.alt { background: {{ theme.colors.navy_light }}; }
  .section h2 {
    font-family: '{{ theme.fonts.display.google_font }}', {{ theme.fonts.display.fallback_stack }};
    color: {{ theme.colors.gold }};
    font-size: 16px;
    margin: 0 0 6px;
  }
  .section p { margin: 0; font-size: 12.5px; line-height: 1.5; }

  /* Floated (not flex) so the heading/body text actually wraps around the image
     instead of sitting in a fixed side-by-side column next to it. */
  .section .pic {
    position: relative;
    width: 180px;
    float: left;
    margin: 0 14px 8px 0;
  }
  .section.imgright .pic { float: right; margin: 0 0 8px 14px; }
  .section .pic img { width: 100%; display: block; border-radius: 6px; }
  .section .pic .badge {
    position: absolute;
    bottom: 6px; right: 6px;
    width: 26px; height: 26px;
    padding: 4px;
    background: rgba(0, 0, 0, 0.45);
    border-radius: 50%;
    object-fit: contain;
  }

  .cta {
    display: inline-block; margin-top: 8px; padding: 5px 14px;
    border-radius: {{ theme.button.border_radius_px }}px;
    background: {{ theme.colors.gold }}; color: {{ theme.colors.text_on_gold }};
    font-size: 11px; font-weight: 600; text-decoration: none;
  }

  .sources { padding: 10px 24px 18px; }
  .sources .label {
    color: {{ theme.colors.sterling_silver }};
    font-size: 9px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;
  }
  .sources a {
    color: {{ theme.colors.gold }}; font-size: 9.5px; text-decoration: none;
    display: block; margin: 2px 0;
  }
</style>
</head>
<body>
  <div class="page">
    <div class="header">
      {% if images.logo %}<img src="{{ images.logo }}" alt="{{ theme.name }}">{% endif %}
      <div class="kicker">{{ content.preheader }}</div>
      <div class="divider"></div>
    </div>

    {% for section in content.sections %}
    <div class="section {{ 'alt' if loop.index is odd else '' }} {{ 'imgright' if loop.index is even else '' }}">
      {% if section.image_cid and images[section.image_cid] %}
      <div class="pic">
        <img src="{{ images[section.image_cid] }}" alt="">
        {% if images.logo %}<img class="badge" src="{{ images.logo }}" alt="">{% endif %}
      </div>
      {% endif %}
      <h2>{{ section.heading }}</h2>
      <p>{{ section.body }}</p>
      {% if section.cta %}<a class="cta" href="{{ section.cta.url }}">{{ section.cta.text }}</a>{% endif %}
    </div>
    {% endfor %}

    {% if content.sources %}
    <div class="sources">
      <div class="label">Sources</div>
      {% for src in content.sources %}
      <a href="{{ src.url }}">{{ src.title }}</a>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</body>
</html>
