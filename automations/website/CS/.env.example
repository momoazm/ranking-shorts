# CS project — vector database credentials.
# Copy this file to `.env` and fill in your Pinecone key. `.env` is gitignored.
#
# GEMINI_API_KEY is optional here: if left blank, the tools fall back to the
# shared root API.env (one level up) which already holds it.

PINECONE_API_KEY=
PINECONE_INDEX=media-memory
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
GEMINI_API_KEY=
